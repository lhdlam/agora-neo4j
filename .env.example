# =============================================================
# Agora — Environment Configuration
# Copy this file to .env and fill in your values.
#
# Rules:
#   - Variables without defaults MUST be set (app/docker fail fast if missing)
#   - Variables with defaults can be left as-is for local dev
#   - On ECS: inject secrets via Task Definition / Secrets Manager, no .env needed
# =============================================================

# ── Elasticsearch (App) ───────────────────────────────────────
ES_HOST=localhost
ES_PORT=9200
ES_SCHEME=http              # "https" for production / Elastic Cloud
ES_INDEX=listings
ES_USER=elastic             # basic-auth user (required by ES 8.x)
ES_PASSWORD=changeme        # override via ECS secrets in production

# Index topology (single-node dev defaults — scale up for production)
ES_NUM_SHARDS=1
ES_NUM_REPLICAS=0

# ── Elasticsearch (Docker) ────────────────────────────────────
ES_IMAGE_TAG=elasticsearch:8.13.4
ES_CLUSTER_NAME=agora-cluster
ES_NODE_NAME=es-node-1
ES_JAVA_OPTS=-Xms1g -Xmx1g  # increase for production (e.g. -Xms4g -Xmx4g)

# ── Kibana (Docker) ───────────────────────────────────────────
KIBANA_IMAGE_TAG=kibana:8.13.4
KIBANA_PORT=5601

# ── Kafka (App) ───────────────────────────────────────────────
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_LISTING=listing.events

# ── Kafka (Docker) ────────────────────────────────────────────
KAFKA_IMAGE_TAG=7.6.1
KAFKA_PORT=9092
KAFKA_NUM_PARTITIONS=3

# Async write mode — set both to true to enable the distributed worker pattern:
#   CLI commands queue to Kafka → agora-worker consumes → embeds + indexes to ES
# Keep false for local dev without Kafka running (sync mode).
KAFKA_WRITE_MODE=true
KAFKA_TOPIC_COMMANDS=listing.commands
KAFKA_TOPIC_DLQ=listing.commands.dlq
KAFKA_CONSUMER_GROUP=agora-workers
KAFKA_MAX_POLL_RECORDS=10


# ⚠️  DEV ONLY — regenerate per deployment: kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg

# ── Monitoring ports (Docker) ─────────────────────────────────
ES_EXPORTER_IMAGE_TAG=v1.7.0
ES_EXPORTER_PORT=9114

PROMETHEUS_IMAGE_TAG=v2.51.2
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

GRAFANA_IMAGE_TAG=10.4.2
GRAFANA_PORT=3000
GRAFANA_USER=admin          # change in production
GRAFANA_PASSWORD=admin      # change in production

# ── Docker healthcheck defaults ───────────────────────────────
HEALTHCHECK_INTERVAL=15s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3

# ── Embedding Model (App) ─────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DIMS=768           # must match model output and ES index mapping
EMBEDDING_DEVICE=cpu         # "cuda" if GPU is available

# ── Matching Parameters (App) ─────────────────────────────────
MATCH_TOP_K=10
MATCH_NUM_CANDIDATES=50
MATCH_MIN_COSINE_SCORE=0.65
MATCH_BONUS_SAME_CATEGORY=0.07
MATCH_BONUS_SAME_CITY=0.03
